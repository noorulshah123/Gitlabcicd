RUN apt-get update && \
    apt-get remove -y libnode-dev libnode72 2>/dev/null || true && \
    apt-get autoremove -y && \
    rm -rf /var/lib/apt/lists/*

##### older

RUN npm update minimatch -g 2>/dev/null || true && \
    # Find and update minimatch in all node_modules
    find / -name "package.json" -path "*/minimatch/package.json" \
        -exec dirname {} \; 2>/dev/null | while read dir; do \
        cd "$dir/.." && npm install minimatch@latest 2>/dev/null || true; \
    done

# Fix node-forge (high - needs >= 1.3.2)
RUN npm install -g node-forge@latest 2>/dev/null || true
################

RUN find /opt/conda -path "*/node_modules/basic-ftp" -type d 2>/dev/null | \
    while read dir; do \
        cd "$dir/.." && npm install basic-ftp@5.0.6 --save 2>/dev/null || true; \
    done && \
    find /usr/lib/code-server -path "*/node_modules/basic-ftp" -type d 2>/dev/null | \
    while read dir; do \
        cd "$dir/.." && npm install basic-ftp@5.0.6 --save 2>/dev/null || true; \
    done && \
    npm cache clean --force 2>/dev/null || true

