USER $MAMBA_USER
RUN micromamba update -y -n base nodejs --channel conda-forge 2>/dev/null || true && \
    micromamba update -y -n sagemaker-recovery-mode nodejs --channel conda-forge 2>/dev/null || true && \
    micromamba clean --all --yes 2>/dev/null || true
USER root

######

# FIX 4: code-server bundled node_modules
RUN find /usr/lib/code-server -path "*/node_modules" -type d -maxdepth 3 2>/dev/null | head -3 | \
    while read nm; do \
        cd "$nm/.." && \
        npm install minimatch@10 tar@7 node-forge@1.3.2 2>/dev/null || true; \
    done && \
    npm cache clean --force 2>/dev/null || true


